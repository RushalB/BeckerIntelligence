{
  "version": 2,
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "design_system/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets(.*)", "dest": "/api/index.ts" },
    { "src": "/design_system/(.*)", "dest": "/design_system/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
